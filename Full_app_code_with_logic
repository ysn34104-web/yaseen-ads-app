}

class _Step3DialogState extends State<_Step3Dialog> {
  late DateTime _currentDate;
  late TextEditingController _drumsController;
  late TextEditingController _bagsController;
  late TextEditingController _customDayController;

  bool _adSelected = false;
  bool _aySelected = false;
  bool _saSelected = false;
  bool _naSelected = false;
  bool _adilSelected = false;

  @override
  void initState() {
    super.initState();
    _currentDate = widget.currentDate;
    _drumsController = TextEditingController();
    _bagsController = TextEditingController();
    _customDayController = TextEditingController();

    if (widget.editingEntry != null) {
      _drumsController.text = '${widget.editingEntry!['drums']}';
      _bagsController.text = '${widget.editingEntry!['bags']}';
      List persons = widget.editingEntry!['persons'];
      _adSelected = persons.contains('A.Ditta');
      _aySelected = persons.contains('A.Yar');
      _saSelected = persons.contains('Saleem');
      _naSelected = persons.contains('Nazir');
      _adilSelected = persons.contains('Adil');
    }
  }

  String _getFormattedDate() {
    List<String> months = [
      'Jan',
      'Feb',
      'Mar',
      'Apr',
      'May',
      'Jun',
      'Jul',
      'Aug',
      'Sep',
      'Oct',
      'Nov',
      'Dec'
    ];
    return '${_currentDate.day}-${months[_currentDate.month - 1]}-${_currentDate.year}';
  }

  void _useSameDate() {
    setState(() {});
    _showSnackbar('Using same date', 'info');
  }

  void _useNextDate() {
    setState(() {
      _currentDate = _currentDate.add(Duration(days: 1));
    });
    _showSnackbar('Date advanced to next day', 'info');
  }

  void _usePreviousDate() {
    setState(() {
      _currentDate = _currentDate.subtract(Duration(days: 1));
    });
    _showSnackbar('Date moved to previous day', 'info');
  }

  void _useCustomDate() {
    int day = int.tryParse(_customDayController.text) ?? 0;
    if (day >= 1 && day <= 31) {
      setState(() {
        _currentDate = DateTime(_currentDate.year, _currentDate.month, day);
      });
      _showSnackbar('Date changed to day $day', 'info');
      _customDayController.clear();
    } else {
      _showSnackbar('Please enter a valid day (1-31)', 'error');
    }
  }

  void _selectAll() {
    setState(() {
      _adSelected = true;
      _aySelected = true;
      _saSelected = true;
      _naSelected = true;
      _adilSelected = true;
    });
  }

  void _clearAll() {
    setState(() {
      _adSelected = false;
      _aySelected = false;
      _saSelected = false;
      _naSelected = false;
      _adilSelected = false;
    });
  }

  void _addEntry() {
    int drums = int.tryParse(_drumsController.text) ?? 0;
    int bags = int.tryParse(_bagsController.text) ?? 0;

    if (drums == 0 && bags == 0) {
      _showSnackbar('Please enter at least one item (drums or bags)', 'error');
      return;
    }

    List<String> persons = [];
    if (_adSelected) persons.add('A.Ditta');
    if (_aySelected) persons.add('A.Yar');
    if (_saSelected) persons.add('Saleem');
    if (_naSelected) persons.add('Nazir');
    if (_adilSelected) persons.add('Adil');

    if (persons.isEmpty) {
      _showSnackbar('Please select at least one person', 'error');
      return;
    }

    int total = (drums * DRUM_RATE) + (bags * BAG_RATE);
    double share = persons.isNotEmpty ? total / persons.length : 0;

    Map<String, dynamic> entry = {
      'date': _getFormattedDate(),
      'drums': drums,
      'bags': bags,
      'total': total,
      'persons': persons,
      'share': share,
      'ad': _adSelected ? share.toStringAsFixed(2) : '-',
      'ay': _aySelected ? share.toStringAsFixed(2) : '-',
      'sa': _saSelected ? share.toStringAsFixed(2) : '-',
      'na': _naSelected ? share.toStringAsFixed(2) : '-',
      'adil': _adilSelected ? share.toStringAsFixed(2) : '-',
    };

    widget.onSave(entry);
    Navigator.pop(context);
  }

  void _showSnackbar(String message, String type) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: type == 'success'
            ? Color(0xFF48BB78)
            : type == 'error'
                ? Color(0xFFF56565)
                : Color(0xFF5BA8FF),
        duration: Duration(seconds: 2),
      ),
    );
  }

