  // ==================== LOGIC METHODS ====================

  void _openStep1Window() {
    showDialog(
      context: context,
      builder: (context) => _Step1Dialog(
        totalEntries: totalEntries,
        onSave: (value) {
          setState(() {
            totalEntries = value;
            currentEntry = 0;
            entries.clear();
            editingIndex = -1;
            _updateStepIndicator();
          });
          _showNotification(
              'Set to $totalEntries entries. Now set the date.', 'success');
        },
      ),
    );
  }

  void _openStep2Window() {
    if (totalEntries == 0) {
      _showNotification('Please set total entries first', 'error');
      return;
    }
    showDialog(
      context: context,
      builder: (context) => _Step2Dialog(
        currentDate: currentDate,
        onSave: (date) {
          setState(() {
            currentDate = date;
            _updateStepIndicator();
          });
          _showNotification('Date set. You can now add entries.', 'success');
        },
      ),
    );
  }

  void _openStep3Window() {
    if (totalEntries == 0) {
      _showNotification('Please set total entries first', 'error');
      return;
    }
    if (currentDate == null) {
      _showNotification('Please set date first', 'error');
      return;
    }
    showDialog(
      context: context,
      builder: (context) => _Step3Dialog(
        currentDate: currentDate!,
        editingIndex: editingIndex,
        editingEntry: editingIndex >= 0 ? entries[editingIndex] : null,
        onSave: (entry) {
          setState(() {
            if (editingIndex >= 0) {
              entries[editingIndex] = entry;
              editingIndex = -1;
              _showNotification('Entry updated successfully', 'success');
            } else {
              entries.add(entry);
              currentEntry++;
              _showNotification(
                  'Entry ${entries.length} added successfully', 'success');
            }
            _updateStepIndicator();
          });
        },
      ),
    );
  }

  void _editEntry(int index) {
    editingIndex = index;
    _openStep3Window();
  }

  void _deleteEntry(int index) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text('Delete Entry'),
        content: Text('Are you sure you want to delete entry ${index + 1}?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: Text('Cancel'),
          ),
          TextButton(
            onPressed: () {
              setState(() {
                entries.removeAt(index);
                currentEntry = entries.length;
                if (editingIndex == index) editingIndex = -1;
                if (editingIndex > index) editingIndex--;
                _updateStepIndicator();
              });
              Navigator.pop(context);
              _showNotification(
                  'Entry ${index + 1} deleted successfully', 'success');
            },
            child: Text('Delete', style: TextStyle(color: Color(0xFFF56565))),
          ),
        ],
      ),
    );
  }

  void _updateStepIndicator() {
    // This will trigger rebuild
    setState(() {});
  }

  void _showNotification(String message, String type) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: type == 'success'
            ? Color(0xFF48BB78)
            : type == 'error'
                ? Color(0xFFF56565)
                : Color(0xFF5BA8FF),
        behavior: SnackBarBehavior.floating,
        duration: Duration(seconds: 3),
      ),
    );
  }
}

