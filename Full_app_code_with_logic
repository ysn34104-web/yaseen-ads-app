  Widget _buildStepIndicator(
      int step, String label, bool isCompleted, bool isActive) {
    Color gradientColor1, gradientColor2, textColor;

    if (isCompleted) {
      gradientColor1 = Color(0xFF48BB78);
      gradientColor2 = Color(0xFF38A169);
      textColor = Colors.white;
    } else if (isActive) {
      gradientColor1 = Color(0xFFFF7B6B);
      gradientColor2 = Color(0xFFFF5A5A);
      textColor = Colors.white;
    } else {
      gradientColor1 = Color(0xFFE2E8F0);
      gradientColor2 = Color(0xFFCBD5E0);
      textColor = Color(0xFF718096);
    }

    return Column(
      children: [
        Container(
          width: 44,
          height: 44,
          decoration: BoxDecoration(
            shape: BoxShape.circle,
            gradient: LinearGradient(
              colors: [gradientColor1, gradientColor2],
            ),
          ),
          child: Center(
            child: Text(
              '$step',
              style: TextStyle(
                fontSize: 20,
                fontWeight: FontWeight.bold,
                color: textColor,
              ),
            ),
          ),
        ),
        SizedBox(height: 8),
        Text(
          label,
          style: TextStyle(
            fontSize: 12,
            fontWeight: FontWeight.w700,
            color: isActive ? Color(0xFFFF7B6B) : Color(0xFF718096),
          ),
        ),
      ],
    );
  }

